<section class="ui center aligned middle aligned segment">

    <div class="dashboard-header">
        <h2>{{title}}</h2>

        <form action="/searchCategory" method="GET" class="ui form">

            <div class="ui inline fields">
                <div class="field">
                    <input type="text" name="searchTerm" placeholder="Search by title..." value="{{search}}">
                </div>

                <div class="field">
                    <label>Sort by:</label>
                    <select class="ui dropdown" name="sort" onchange="this.form.submit()">
                        <option value="title" {{#if titleSelected}}selected{{/if}}>Title</option>
                        <option value="movieCount" {{#if movieCountSelected}}selected{{/if}}>Movie Count</option>
                    </select>
                </div>

                <div class="field">
                    <label>Order:</label>
                    <select class="ui dropdown" name="order" onchange="this.form.submit()">
                        <option value="asc" {{#if ascSelected}}selected{{/if}}>↑</option>
                        <option value="desc" {{#if descSelected}}selected{{/if}}>↓</option>
                    </select>
                </div>
            </div>

        </form>
    </div>

    {{#unless search}}
    {{#unless movieCatalogue}}
    <h3 class="ui message">
        Movie catalogue is empty!
    </h3>
    {{/unless}}
    {{/unless}}

    <div class="ui equal height centered cards">
        {{#each movieCatalogue}}
        <div class="card">
            <div class="content">
                <div class="header">{{title}}</div>
                <div class="meta">Movie Count: {{movies.length}}</div>
            </div>
            <div class="extra content">
                <a href="/movie/{{id}}" class="ui primary button">View Now <i class="eye icon"
                        style="margin-left: 4px;"></i></a>
                <a href="/dashboard/deletecollection/{{id}}">
                    <i class="ui trash black icon"></i>
                </a>
            </div>
        </div>
        {{/each}}
    </div>

</section>