<form class="ui stacked segment form" action="/movie/{{id}}/addmovie" method="POST">
    <div class="two fields">
        <div class="field">
            <label>Title</label>
            <input type="text" name="title" autofocus required title="Please include a valid Title" placeholder="Title">
        </div>
        <div class="field">
            <label>Director</label>
            <input type="text" name="director" required title="Please include a valid Director" placeholder="Director">
        </div>
        <div class="field">
            <label>Release Year</label>
            <input type="number" name="releaseYear" required title="Please include a valid release year"
                placeholder="2000">
        </div>
        <div class="field">
            <label>Genre</label>
            <select name="genre" required>
                <option value="">-- Select a Genre --</option>
                <option value="action">Action</option>
                <option value="adventure">Adventure</option>
                <option value="animation">Animation</option>
                <option value="comedy">Comedy</option>
                <option value="crime">Crime</option>
                <option value="documentary">Documentary</option>
                <option value="drama">Drama</option>
                <option value="fantasy">Fantasy</option>
                <option value="horror">Horror</option>
                <option value="mystery">Mystery</option>
                <option value="romance">Romance</option>
                <option value="sci-fi">Sci-Fi</option>
                <option value="thriller">Thriller</option>
                <option value="western">Western</option>
            </select>
        </div>
        <div class="field">
            <label>Rating</label>
            <input type="number" name="rating" required title="Please include a valid rating" placeholder="?/10" min="0"
                max="10">
        </div>
    </div>
    <button class="ui primary button submit">Add Movie</button>
</form>